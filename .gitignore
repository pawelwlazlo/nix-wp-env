.idea/

# devenv
.devenv/
.devenv.flake.nix
devenv.local.nix

# direnv
.direnv/

# Bedrock application (Composer-managed)
web/app/plugins/*
!web/app/plugins/.gitkeep
# Composer-managed default theme (declared in composer.json, regenerated by
# `composer install`). Custom/first-party themes under web/app/themes stay tracked.
web/app/themes/twentytwentyfive/
# Ignore Composer-installed mu-plugin package directories; single-file mu-plugins are tracked intentionally
web/app/mu-plugins/*/
web/app/uploads/*
!web/app/uploads/.gitkeep

# WordPress core (Composer-managed)
web/wp/

# Composer
vendor/

# Dotenv
.env
.env.*
!.env.example
